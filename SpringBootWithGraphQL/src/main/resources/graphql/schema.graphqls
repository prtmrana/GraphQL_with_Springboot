type User {
    userId: ID
    userName: String
    userEmail: String
    userMobile: String
    userRole: String
    userActive: String
}

type Query {
    getAllUsers: [User]
    getUserById(userId: ID): User
    getRoleByRoleName(roleName: String): Role
}


type Role {
    roleDept: String
    rolePosition: String
    roleName: String
    roleStatus: String
}