package com.example.demo.service;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import com.example.demo.entity.UserMasterEntity;
import com.example.demo.repository.UserMasterRepository;

@Service
public class UserService {

    @Autowired
    private UserMasterRepository repo;

    public List<UserMasterEntity> getAllUsers() {
        return (List<UserMasterEntity>) repo.findAll();
    }

    public UserMasterEntity getUserById(String id) {
        return repo.findById(id).orElse(null);
    }

    public UserMasterEntity createUser(String name, String email) {
    	UserMasterEntity user = new UserMasterEntity();
        user.setUserName(name);
        user.setUserEmail(email);
        return repo.save(user);
    }
}